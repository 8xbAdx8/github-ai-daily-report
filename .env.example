# === Required ===
# DeepSeek API Key (https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# === Optional: Chat Platform Webhooks ===
# 企业微信机器人 Webhook (https://developer.work.weixin.qq.com/document/path/91770)
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 钉钉机器人 Webhook (https://open.dingtalk.com/document/orgapp/custom-bot-send-message-type)
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token

# 飞书机器人 Webhook (https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# Telegram Bot (https://core.telegram.org/bots#how-do-i-create-a-bot)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Server酱 — 推送至个人微信 (https://sct.ftqq.com/)
SERVERCHAN_SENDKEY=SCTxxxxxxxxxxxxx
